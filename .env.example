
# Hugging Face — used for Whisper transcription (distil-whisper/distil-whisper-large-v2)
HF_TOKEN=hf_your_token_here

# Groq — LLM feedback worker (Llama 3 / Mistral via OpenAI-compatible API)
GROQ_API_KEY=gsk_your_key_here
GROQ_BASE_URL=https://api.groq.com/openai

# AWS S3 — audio recording storage
S3_BUCKET=speech-practice-app
AWS_REGION=eu-west-1

# Amazon MSK (Kafka) bootstrap servers
MSK_BOOTSTRAP=localhost:9092

# Redis / ElastiCache — session status cache
REDIS_URL=redis://localhost:6379