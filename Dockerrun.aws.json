{
  "AWSEBDockerrunVersion": 2,
  "containerDefinitions": [
    {
      "name": "speech-practice-app",
      "image": "kaiyuewei/speech-practice-app:latest",
      "essential": true,
      "memory": 512,
      "portMappings": [
        {
          "hostPort": 80,
          "containerPort": 8080
        }
      ],
      "environment": [
        {
          "name": "SPRING_PROFILES_ACTIVE",
          "value": "test"
        }
      ]
    }
  ]
}